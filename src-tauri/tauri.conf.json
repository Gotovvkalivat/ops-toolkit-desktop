{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OPS Toolkit",
  "version": "0.5.3",
  "identifier": "ru.opspost.toolkit",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "OPS Toolkit",
        "url": "http://127.0.0.1:48731/",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["../desktop-assets/ops-toolkit.ico"],
    "externalBin": ["binaries/OpsToolkit.Desktop.Server"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
